# Copy to ".env" and fill in. All values are optional except where noted.

# Port the server listens on
PORT=3000

# Protects the /admin lead dashboard. If unset, a random token is printed to the
# console each time the server starts.
ADMIN_TOKEN=change-me-to-a-long-random-string

# ---- Email notifications for new leads (optional) --------------------------
# Leave SMTP_HOST blank to disable email (leads are still saved to the database).
# Example below is for a typical SMTP provider (e.g. Mailgun, SendGrid, Gmail app password).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BlueCrest Pressure Washing <hello@bluecrestwash.com>"
LEAD_NOTIFY_TO=owner@bluecrestwash.com

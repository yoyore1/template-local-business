{
  "name": "template-local-business",
  "version": "1.0.0",
  "private": true,
  "description": "Template: premium conversion-focused website + lead-capture backend for a local pressure washing business.",
  "type": "module",
  "scripts": {
    "start": "node --experimental-sqlite --no-warnings server.js",
    "dev": "node --experimental-sqlite --no-warnings --watch server.js",
    "fetch-images": "node scripts/fetch-images.mjs",
    "fetch-fonts": "node scripts/fetch-fonts.mjs",
    "build": "node scripts/build-static.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.9.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "sharp": "^0.35.2"
  }
}
